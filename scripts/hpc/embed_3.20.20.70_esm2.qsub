#!/bin/bash
#$ -S /bin/bash
#$ -cwd
#$ -N embed_3.20.20.70_esm2
#$ -l tmem=16G
#$ -l h_rt=1:00:00
#$ -l gpu=true
#$ -l h=bubba-213-1
#$ -j y

set -e

echo "========================================"
echo "Job started on host: $(hostname)"
echo "Start time: $(date)"
echo "========================================"

# Activate virtual environment
source /SAN/orengolab/functional-families/janu/contrasted-ff/.venv/bin/activate

# Sanity checks
echo "CUDA_VISIBLE_DEVICES=$CUDA_VISIBLE_DEVICES"
nvidia-smi

export PYTHONUNBUFFERED=1

# Redirect HuggingFace cache off home (quota issues)
export HF_HOME=/SAN/orengolab/functional-families/janu/.hf_cache
export TRANSFORMERS_CACHE=/SAN/orengolab/functional-families/janu/.hf_cache

# Step 1: Generate ESM2 embeddings into LMDB
CUDA_VISIBLE_DEVICES=0 \
python /SAN/orengolab/functional-families/janu/contrasted-ff/scripts/embed-esm2.py \
  --input   /SAN/orengolab/functional-families/janu/contrasted-ff/HUPs_data/3.20.20.70/3.20.20.70_sc_reps.fasta \
  --output  /SAN/orengolab/functional-families/janu/contrasted-ff/HUPs_data/3.20.20.70/3.20.20.70_sc_reps_esm2.lmdb \
  --half 1 --per_protein 1 \
  --map_size_gb 1 \
  --bucket_size 4000 \
  --commit_every 4000

# Step 2: Convert LMDB to .pt
python /SAN/orengolab/functional-families/janu/contrasted-ff/scripts/lmdb_to_pt.py \
  --lmdb_path /SAN/orengolab/functional-families/janu/contrasted-ff/HUPs_data/3.20.20.70/3.20.20.70_sc_reps_esm2.lmdb \
  --output    /SAN/orengolab/functional-families/janu/contrasted-ff/HUPs_data/3.20.20.70/3.20.20.70_sc_reps_esm2.pt

echo "========================================"
echo "Job finished at: $(date)"
echo "========================================"
